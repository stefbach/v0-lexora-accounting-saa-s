        "options": {
          "queryReplacement": "={{ $node['Webhook — Telegram payload from Lexora'].json.body.chat_id }},{{ $node['Webhook — Telegram payload from Lexora'].json.body.societe_id }},{{ $node['AI Agent — Claude Sonnet 4.6'].json.output }}"
        }
      },
      "id": "log2",
      "name": "Postgres — log assistant reply",
