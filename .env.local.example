# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cron Jobs (Vercel)
CRON_SECRET=generate_a_random_secret_here

# Alertes WhatsApp (WATI)
WATI_API_KEY=
WATI_API_URL=https://live-mt-server.wati.io/XXXXX

# Email (Resend)
RESEND_API_KEY=

# Exchange Rates (exchangerate-api.com)
EXCHANGE_RATE_API_KEY=

# MRA Fiscalisation (Mauritius Revenue Authority)
MRA_MODE=mock                       # mock | sandbox | production
MRA_EBS_ID=
MRA_API_ENDPOINT=                   # ex: https://vfisc.mra.mu/realapi
MRA_CERT_PATH=                      # chemin absolu vers certificat X.509 (PEM)
MRA_CERT_PASSWORD=
MRA_TAXPAYER_TAN=
# Si MRA_MODE=production et qu'une des variables MRA_* ci-dessus manque,
# getMraConfig() lève une erreur par défaut (évite de fiscaliser avec un IRN mock
# en production). Mettre à 'true' pour autoriser le downgrade silencieux vers
# mock dans ce cas (compliance risk — à utiliser uniquement en staging/dev).
MRA_ALLOW_FALLBACK_TO_MOCK=false

# PII encryption key for NIC/NPF/IBAN (DPA 2017 compliance)
# Must be at least 32 characters, random. Never commit real values.
# Generate: openssl rand -base64 32
PII_ENCRYPTION_KEY=
