# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cron Jobs (Vercel)
CRON_SECRET=generate_a_random_secret_here

# Alertes WhatsApp (WATI)
WATI_API_KEY=
WATI_API_URL=https://live-mt-server.wati.io/XXXXX

# Email (Resend)
RESEND_API_KEY=

# Exchange Rates (exchangerate-api.com)
EXCHANGE_RATE_API_KEY=

# n8n (workflow automation)
N8N_BASE_URL=https://n8n.example.com
N8N_API_KEY=

# Agent endpoints (n8n → Lexora)
# Secret partagé qui authentifie les appels n8n → /api/agent/*.
# Génère-le avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DOIT être configuré dans Vercel pour le déploiement de Lexora.
LEXORA_AGENT_SECRET=

# URL publique de Lexora (utilisée par les scripts n8n)
LEXORA_BASE_URL=https://www.lexora.finance
