# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase MCP server (.mcp.json)
# SUPABASE_PROJECT_REF: visible dans le dashboard Supabase (Settings → General).
#   C'est la partie avant ".supabase.co" dans NEXT_PUBLIC_SUPABASE_URL.
# SUPABASE_ACCESS_TOKEN: Personal Access Token (PAT), pas la service_role.
#   À créer ici: Supabase Dashboard → Account → Access Tokens → Generate new token
#   Doit être exporté dans le shell avant de lancer Claude Code.
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cron Jobs (Vercel)
CRON_SECRET=generate_a_random_secret_here

# Alertes WhatsApp (WATI)
WATI_API_KEY=
WATI_API_URL=https://live-mt-server.wati.io/XXXXX

# Email (Resend)
RESEND_API_KEY=

# Exchange Rates (exchangerate-api.com)
EXCHANGE_RATE_API_KEY=

# n8n (workflow automation)
# Used by scripts/sync-n8n.mjs AND by the n8n-mcp MCP server (.mcp.json)
# Both vars must be exported in your shell before launching Claude Code,
# otherwise the MCP server cannot authenticate.
N8N_BASE_URL=https://n8n.example.com
N8N_API_KEY=

# Agent endpoints (n8n → Lexora)
# Secret partagé qui authentifie les appels n8n → /api/agent/*.
# Génère-le avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DOIT être configuré dans Vercel pour le déploiement de Lexora.
LEXORA_AGENT_SECRET=

# URL publique de Lexora (utilisée par les scripts n8n)
LEXORA_BASE_URL=https://www.lexora.finance

# ====== Telegram Bot (Option A : 1 bot multi-tenant) ======
# Token donné par @BotFather (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
# Username du bot sans le @ (ex: LexoraBot)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=LexoraBot
# Secret Telegram (header X-Telegram-Bot-Api-Secret-Token)
# Génère avec: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# Token d'authentification interne pour /api/telegram/send et /cron-alerts
# Génère avec: openssl rand -hex 32
INTERNAL_API_TOKEN=
# URL du webhook n8n qui héberge l'AI Agent (Anthropic Claude Sonnet 4.6)
N8N_TELEGRAM_AGENT_WEBHOOK=https://n8n.exemple.com/webhook/lexora-telegram-agent
